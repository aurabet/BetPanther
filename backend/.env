# Variables d'environnement pour le backend BookMaker Africa

# Port d'écoute du serveur
PORT=3000

# Clé secrète pour JWT (à changer en production)
JWT_SECRET=your_jwt_secret_key_here

# URL de la base de données (à configurer selon votre setup)
DATABASE_URL=postgresql://username:password@localhost:5432/bookmaker_africa

# Configuration Redis (si utilisé)
REDIS_URL=redis://localhost:6379

# Configuration Supabase (si utilisé)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Configuration d'autres services externes
API_KEY=your_api_key
API_SECRET=your_api_secret

# Mode d'environnement
NODE_ENV=development

# Configuration CORS
CORS_ORIGIN=http://localhost:5173

# Configuration de sécurité
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key